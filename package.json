{
  "name": "agentic-trader-workspace",
  "version": "0.16.15",
  "private": true,
  "license": "LGPL-3.0-or-later",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bootstrap": "scripts/bootstrap-system-tools.sh",
    "bootstrap:dry-run": "scripts/bootstrap-system-tools.sh --dry-run",
    "launch:main": "scripts/launch-main.sh",
    "setup": "pnpm run setup:node && pnpm run setup:camofox && pnpm run install:python",
    "setup:tools": "uv run --locked --all-extras --group dev agentic-trader setup-status",
    "app:doctor": "node scripts/app-doctor.mjs",
    "app:up": "node scripts/app-up.mjs",
    "app:setup": "node scripts/app-setup.mjs",
    "app:start": "node scripts/app-services.mjs start",
    "app:stop": "node scripts/app-services.mjs stop",
    "app:update": "node scripts/app-update.mjs",
    "app:uninstall": "node scripts/app-uninstall.mjs",
    "setup:camofox": "scripts/run-camofox-pnpm.sh install --ignore-scripts",
    "fetch:camofox": "scripts/run-camofox-pnpm.sh run fetch:browser",
    "check:camofox": "scripts/run-camofox-pnpm.sh run test",
    "setup:node": "scripts/setup-node-workspace.sh",
    "install:python": "scripts/install-python.sh",
    "install:node": "pnpm run setup:node",
    "setup:research-flow": "uv sync --locked --all-packages --all-extras --group dev",
    "setup:research-crewai": "pnpm run setup:research-flow",
    "check": "pnpm run qa:prompts && pnpm run qa:modularity && pnpm run check:python && pnpm run check:node",
    "check:python": "scripts/check-python.sh",
    "check:research-flow": "sh scripts/check-research-flow.sh",
    "check:research-crewai": "pnpm run check:research-flow",
    "check:node": "pnpm run lint && pnpm run typecheck && pnpm run build",
    "security:actions": "python3 scripts/security/check_github_actions_pinning.py",
    "security:secrets": "python3 scripts/security/high_confidence_secret_scan.py",
    "security:node-audit": "pnpm audit --audit-level moderate",
    "security:check": "pnpm run security:actions && pnpm run security:secrets && pnpm run security:node-audit",
    "test:node": "vitest run",
    "test:node:coverage": "vitest run --coverage",
    "lint": "pnpm --filter webgui run lint && pnpm --filter docs run lint",
    "typecheck": "pnpm --filter webgui run typecheck && pnpm --filter docs run typecheck",
    "build": "pnpm run build:webgui && pnpm run build:docs && pnpm run check:tui",
    "build:webgui": "pnpm --filter webgui run build",
    "build:docs": "pnpm --filter docs run build",
    "build:docs:pages": "GITHUB_PAGES=true pnpm --filter docs run build",
    "check:tui": "pnpm --filter agentic-trader-tui exec node --check index.mjs && pnpm --filter agentic-trader-tui exec node --input-type=module -e \"await import('ink')\" && pnpm --filter agentic-trader-tui run test",
    "test:webgui:coverage": "vitest run webgui/src tui docs --coverage --coverage.reporter=lcov --coverage.reportsDirectory=.ai/qa/artifacts/sonar/webgui-coverage",
    "qa": "uv run --locked --all-extras --group dev python scripts/qa/smoke_qa.py",
    "qa:modularity": "uv run --locked --all-extras --group dev python scripts/qa/modularity_i18n_audit.py --fail-on-findings",
    "qa:modularity:report": "uv run --locked --all-extras --group dev python scripts/qa/modularity_i18n_audit.py",
    "qa:prompts": "uv run --locked --all-extras --group dev python scripts/qa/prompt_docs_lint.py",
    "qa:quality": "pnpm run qa:prompts && uv run --locked --all-extras --group dev python scripts/qa/smoke_qa.py --include-quality",
    "qa:v1-paper-desk": "uv run --locked --all-extras --group dev python scripts/qa/v1_paper_desk_rehearsal.py",
    "qa:sonar": "pnpm run qa:prompts && uv run --locked --all-extras --group dev python scripts/qa/smoke_qa.py --include-quality --include-sonar",
    "version:plan": "scripts/release/preview_version_plan.sh",
    "release:preview": "uv run --locked --all-extras --group dev semantic-release --noop version --print-tag",
    "sonar": "pnpm run sonar:local",
    "sonar:install": "scripts/sonarqube/install-tools.sh",
    "sonar:start": "scripts/sonarqube/start-local.sh",
    "sonar:stop": "scripts/sonarqube/stop-local.sh",
    "sonar:status": "scripts/sonarqube/status-local.sh",
    "sonar:repair-db-password": "scripts/sonarqube/repair-db-password.sh",
    "sonar:local": "pnpm run sonar:local:py",
    "sonar:local:py": "scripts/qa/run_sonar_scan.sh pysonar",
    "sonar:local:js": "scripts/qa/run_sonar_scan.sh npm",
    "sonar:py": "pnpm run sonar:local:py",
    "sonar:js": "pnpm run sonar:local:js",
    "sonar:cloud": "SONAR_HOST_URL=https://sonarcloud.io SONAR_PROJECT_KEY=ogiboy_agentic-trader SONAR_ORGANIZATION=ogiboy SONAR_TOKEN_KEYCHAIN_SERVICE=codex-sonarcloud-token scripts/qa/run_sonar_scan.sh npm",
    "sonar:cloud:py": "SONAR_HOST_URL=https://sonarcloud.io SONAR_PROJECT_KEY=ogiboy_agentic-trader SONAR_ORGANIZATION=ogiboy SONAR_TOKEN_KEYCHAIN_SERVICE=codex-sonarcloud-token scripts/qa/run_sonar_scan.sh pysonar",
    "secret:sonar:check": "scripts/secrets/keychain-get.sh --check codex-sonarqube-token",
    "secret:sonarcloud:check": "scripts/secrets/keychain-get.sh --check codex-sonarcloud-token",
    "mcp:sonarqube:dry-run": "SONARQUBE_MCP_DRY_RUN=1 scripts/secrets/run-sonarqube-mcp.sh",
    "mcp:sonarqube:status": "scripts/secrets/check-sonarqube-mcp.sh",
    "mcp:sonarqube:install-wrapper": "scripts/secrets/install-sonarqube-mcp-wrapper.sh",
    "run:research-flow": "sh scripts/run-research-flow.sh",
    "run:research-crewai": "pnpm run run:research-flow",
    "start:camofox": "scripts/start-camofox-browser.sh",
    "dev:webgui": "AGENTIC_TRADER_WEBGUI_LOOPBACK_ONLY=1 WATCHPACK_POLLING=true pnpm --filter webgui exec next dev --hostname 127.0.0.1 -p 3210",
    "dev:docs": "pnpm --filter docs run dev",
    "start:tui": "pnpm --filter agentic-trader-tui run start",
    "clean": "scripts/clean-workspace.sh",
    "clean:deps": "scripts/clean-workspace.sh --deps",
    "clean:all": "scripts/clean-workspace.sh --all"
  },
  "devDependencies": {
    "@sonar/scan": "^4.3.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.10"
  },
  "workspaces": [
    "webgui",
    "docs",
    "tui"
  ],
  "overrides": {
    "adm-zip": "0.6.0",
    "axios": "1.16.1",
    "fast-uri": "3.1.2",
    "form-data": "4.0.6",
    "hono": "4.12.25",
    "ip-address": "10.1.1",
    "postcss": "8.5.10",
    "qs": "6.15.2",
    "undici": "7.28.0",
    "vite": "8.0.16"
  }
}
