# Copy this file to `docs/.env.local` to enable GitHub Discussions forwarding
# for the Fumadocs feedback widget.
#
# Keep the private key on a single line with literal `\n` separators.

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

DOCS_FEEDBACK_GITHUB_OWNER=ogiboy
DOCS_FEEDBACK_GITHUB_REPO=agentic-trader
DOCS_FEEDBACK_GITHUB_CATEGORY="Docs Feedback"
