# Local docs development usually needs no environment variables.
# Copy this file to `docs/.env.local` only for machine-local overrides.
# Keep GITHUB_PAGES=false locally; GitHub Actions and `pnpm build:docs:pages`
# set it to true for the GitHub Pages static export.
NEXT_PUBLIC_BASE_PATH=

# GitHub Pages static export settings. NEXT_PUBLIC_BASE_PATH is computed from
# these values by `docs/next.config.mjs` during the build.
GITHUB_PAGES=false
GITHUB_PAGES_REPO_NAME=agentic-trader
