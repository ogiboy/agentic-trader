# Local docs development usually needs no environment variables.
# Copy this file to `docs/.env.local` only for machine-local overrides.
# Keep GITHUB_PAGES=false locally. GitHub Actions and `pnpm build:docs:pages`
# set GITHUB_PAGES=true at build time for the GitHub Pages static export.
NEXT_PUBLIC_BASE_PATH=

# GitHub Pages static export settings. Leave NEXT_PUBLIC_BASE_PATH empty unless
# testing a custom base path; otherwise `docs/next.config.mjs` derives it from
# GITHUB_PAGES_REPO_NAME when GITHUB_PAGES=true.
GITHUB_PAGES=false
GITHUB_PAGES_REPO_NAME=agentic-trader
