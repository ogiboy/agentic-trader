{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "fumadocs-mdx && CHOKIDAR_USEPOLLING=true WATCHPACK_POLLING=true next dev",
