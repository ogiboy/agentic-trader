{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python-envs.defaultPackageManager": "ms-python.python:uv",
  "sonarlint.connectedMode.project": {
    "connectionId": "local server",
    "projectKey": "agentic-trader"
  },
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.useEnvFile": true,
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": true,
  "python.testing.pytestEnabled": true,
  "markdown.preview.doubleClickToSwitchToEditor": true,
  "editor.defaultFormatter": "ms-python.black-formatter",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "isort.args": ["--profile", "black"],
  "python.analysis.autoImportCompletions": true,
  "python-envs.pythonProjects": [],
  "python.createEnvironment.contentButton": "show",
  "python.languageServer": "Pylance",
  "pylint.args": [""],
  "python.analysis.aiCodeActions": {
    "generateDocstring": true,
    "implementAbstractClasses": true,
    "generateSymbol": true,
    "convertFormatString": true
  },
  "isort.check": true,
  "python.analysis.includeExtraPathSymbolsInSymbolSearch": true,
  "python.analysis.includeVenvInWorkspaceSymbols": true,
  "python.analysis.inlayHints.callArgumentNames": "all",
  "editor.fontFamily": "'Courier New', monospace, Arial",
  "editor.fontSize": 12,
  "editor.fontVariations": true,
  "editor.letterSpacing": 2.33,
  "editor.minimap.sectionHeaderLetterSpacing": 10,
  "editor.cursorStyle": "underline",
  "editor.minimap.autohide": "mouseover",
  "editor.inlineSuggest.fontFamily": "\"Less Perfect DOS VGA\", default",
  "files.encoding": "iso88599",
  "workbench.activityBar.compact": false,
  "workbench.fontAliasing": "default",
  "window.autoDetectColorScheme": false,
}
