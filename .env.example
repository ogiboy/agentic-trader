AGENTIC_TRADER_MODEL=qwen3:8b
AGENTIC_TRADER_BASE_URL=http://localhost:11434/v1
AGENTIC_TRADER_TEMPERATURE=0.0
AGENTIC_TRADER_STRICT_LLM=true
AGENTIC_TRADER_ALLOW_SHORT=true
AGENTIC_TRADER_DEFAULT_POLL_SECONDS=300
AGENTIC_TRADER_RUNTIME_DIR=runtime
AGENTIC_TRADER_DATABASE_PATH=runtime/agentic_trader.duckdb
AGENTIC_TRADER_MAX_OUTPUT_TOKENS=2048
AGENTIC_TRADER_EXECUTION_BACKEND=paper
AGENTIC_TRADER_LIVE_EXECUTION_ENABLED=false
AGENTIC_TRADER_EXECUTION_KILL_SWITCH_ACTIVE=false
AGENTIC_TRADER_NEWS_MODE=off
AGENTIC_TRADER_FINNHUB_API_KEY=
AGENTIC_TRADER_FMP_API_KEY=
AGENTIC_TRADER_POLYGON_API_KEY=
AGENTIC_TRADER_MASSIVE_API_KEY=
AGENTIC_TRADER_ALPACA_API_KEY=
AGENTIC_TRADER_ALPACA_SECRET_KEY=
AGENTIC_TRADER_ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
AGENTIC_TRADER_ALPACA_DATA_FEED=iex

# Optional local SonarQube scanner settings.
# Prefer macOS Keychain service codex-sonarqube-token over setting SONAR_TOKEN here.
SONAR_HOST_URL=http://localhost:9000
SONAR_PROJECT_KEY=agentic-trader
SONAR_PROJECT_NAME="Agentic Trader"
SONAR_TOKEN_KEYCHAIN_SERVICE=codex-sonarqube-token
SONARQUBE_URL=http://host.docker.internal:9000
SONARQUBE_KEYCHAIN_SERVICE=codex-sonarqube-token
SONARQUBE_IDE_PORT=64120

