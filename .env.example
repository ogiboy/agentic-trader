# Agentic Trader runtime environment template.
# Copy this file to `.env.local` for machine-local overrides.
# `.env.example` is tracked documentation only; the Python runtime loads `.env`
# and `.env.local` from the repository root when the CLI runs from this worktree.

AGENTIC_TRADER_LLM_PROVIDER=ollama
AGENTIC_TRADER_MODEL_NAME=qwen3:8b
# Legacy alias accepted by the Python settings layer; prefer MODEL_NAME.
# AGENTIC_TRADER_MODEL=qwen3:8b
AGENTIC_TRADER_BASE_URL=http://localhost:11434/v1
AGENTIC_TRADER_TEMPERATURE=0.0
AGENTIC_TRADER_MAX_RETRIES=2
AGENTIC_TRADER_REQUEST_TIMEOUT_SECONDS=180
AGENTIC_TRADER_MAX_OUTPUT_TOKENS=2048
AGENTIC_TRADER_STRICT_LLM=true

# Optional per-role model overrides. Leave commented to use MODEL_NAME.
# AGENTIC_TRADER_COORDINATOR_MODEL_NAME=
# AGENTIC_TRADER_REGIME_MODEL_NAME=
# AGENTIC_TRADER_STRATEGY_MODEL_NAME=
# AGENTIC_TRADER_RISK_MODEL_NAME=
# AGENTIC_TRADER_MANAGER_MODEL_NAME=
# AGENTIC_TRADER_FUNDAMENTAL_MODEL_NAME=
# AGENTIC_TRADER_MACRO_MODEL_NAME=
# AGENTIC_TRADER_EXPLAINER_MODEL_NAME=
# AGENTIC_TRADER_INSTRUCTION_MODEL_NAME=

AGENTIC_TRADER_RUNTIME_MODE=operation
AGENTIC_TRADER_RUNTIME_DIR=runtime
AGENTIC_TRADER_DATABASE_PATH=runtime/agentic_trader.duckdb
AGENTIC_TRADER_MARKET_DATA_CACHE_DIR=runtime/market_snapshots
AGENTIC_TRADER_MARKET_DATA_MODE=live
AGENTIC_TRADER_NEWS_MODE=off
AGENTIC_TRADER_NEWS_HEADLINE_LIMIT=5
AGENTIC_TRADER_DEFAULT_POLL_SECONDS=300

# Optional research sidecar. Disabled by default; no provider should fetch
# network data unless its explicit enablement and credentials/contact metadata
# are present in an ignored local env file.
AGENTIC_TRADER_RESEARCH_MODE=off
AGENTIC_TRADER_RESEARCH_SIDECAR_ENABLED=false
AGENTIC_TRADER_RESEARCH_SIDECAR_BACKEND=noop
AGENTIC_TRADER_RESEARCH_SYMBOLS=
AGENTIC_TRADER_RESEARCH_POLL_SECONDS=900
AGENTIC_TRADER_RESEARCH_MAX_EVENTS_PER_SOURCE=20
AGENTIC_TRADER_RESEARCH_SEC_EDGAR_ENABLED=false
# Required by SEC fair-access guidance before SEC EDGAR fetching is enabled.
# Use an identifying app/company/contact string in `.env.local`.
AGENTIC_TRADER_RESEARCH_SEC_EDGAR_USER_AGENT=

# Paper-first execution defaults.
AGENTIC_TRADER_EXECUTION_BACKEND=paper
AGENTIC_TRADER_LIVE_EXECUTION_ENABLED=false
AGENTIC_TRADER_EXECUTION_KILL_SWITCH_ACTIVE=false
AGENTIC_TRADER_ALLOW_SHORT=true
AGENTIC_TRADER_MIN_CONFIDENCE=0.6
AGENTIC_TRADER_MAX_POSITION_PCT=0.1
AGENTIC_TRADER_MAX_GROSS_EXPOSURE_PCT=0.8
AGENTIC_TRADER_MAX_OPEN_POSITIONS=5
AGENTIC_TRADER_MIN_RISK_REWARD=1.5
AGENTIC_TRADER_DEFAULT_CASH=100000

# Simulated-real rehearsal is non-live and opt-in.
AGENTIC_TRADER_SIMULATED_SLIPPAGE_BPS=5.0
AGENTIC_TRADER_SIMULATED_SPREAD_BPS=2.0
AGENTIC_TRADER_SIMULATED_PRICE_DRIFT_BPS=3.0
AGENTIC_TRADER_SIMULATED_PARTIAL_FILL_PROBABILITY=0.0
AGENTIC_TRADER_SIMULATED_PARTIAL_FILL_MIN_RATIO=0.5
AGENTIC_TRADER_SIMULATED_ORDER_REJECTION_PROBABILITY=0.0
AGENTIC_TRADER_SIMULATED_LATENCY_MS=0

# Optional data-provider keys. Keep real values only in ignored local env files
# or in GitHub repository secrets when a workflow explicitly needs them.
AGENTIC_TRADER_FINNHUB_API_KEY=
AGENTIC_TRADER_FMP_API_KEY=
AGENTIC_TRADER_POLYGON_API_KEY=
AGENTIC_TRADER_MASSIVE_API_KEY=
AGENTIC_TRADER_ALPACA_API_KEY=
AGENTIC_TRADER_ALPACA_SECRET_KEY=
AGENTIC_TRADER_ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
AGENTIC_TRADER_ALPACA_DATA_FEED=iex
# External Alpaca paper order submission remains off unless this is explicit.
AGENTIC_TRADER_ALPACA_PAPER_TRADING_ENABLED=false

# Optional local SonarQube scanner settings.
# Prefer macOS Keychain service codex-sonarqube-token over setting SONAR_TOKEN here.
SONAR_HOST_URL=http://localhost:9000
SONAR_PROJECT_KEY=agentic-trader
SONAR_PROJECT_NAME="Agentic Trader"
SONAR_TOKEN_KEYCHAIN_SERVICE=codex-sonarqube-token
# SONAR_TOKEN=
# SONAR_TOKEN_KEYCHAIN_ACCOUNT=
# SONAR_BRANCH_NAME=
# SONAR_ORGANIZATION=
# SONAR_REGION=
# SONAR_SOURCES=agentic_trader,main.py,webgui/src,docs/app,docs/components,docs/content,docs/lib,tui
# SONAR_TESTS=tests
# SONAR_ARTIFACT_DIR=.ai/qa/artifacts/sonar
# SONAR_COVERAGE_XML=.ai/qa/artifacts/sonar/coverage.xml
# SONAR_SKIP_COVERAGE=0
SONARQUBE_URL=http://host.docker.internal:9000
SONARQUBE_KEYCHAIN_SERVICE=codex-sonarqube-token
SONARQUBE_IDE_PORT=64120
# SONARQUBE_TOKEN=
# SONARQUBE_KEYCHAIN_ACCOUNT=
# SONARQUBE_COMPOSE_FILE=scripts/sonarqube/docker-compose.sonarqube.yml
# SONARQUBE_MCP_DRY_RUN=0
# SONARQUBE_MCP_WRAPPER_PATH=
# AGENTIC_TRADER_SONAR_MCP_SCRIPT=
# SONAR_POSTGRES_PASSWORD=sonar-local-password
# SONAR_AUTH_JWTBASE64HS256SECRET=agentic-trader-local-sonarqube-dev-secret

# Optional SonarCloud overrides for manual scans.
# SONAR_HOST_URL=https://sonarcloud.io
# SONAR_PROJECT_KEY=ogiboy_agentic-trader
# SONAR_ORGANIZATION=ogiboy
# SONAR_TOKEN_KEYCHAIN_SERVICE=codex-sonarcloud-token
# SONARQUBE_ORG=ogiboy
# SONARQUBE_CLOUD_URL=https://sonarcloud.io
# SONARQUBE_URL=https://sonarcloud.io
# SONARQUBE_KEYCHAIN_SERVICE=codex-sonarcloud-token
