# Optional Web GUI overrides.
# Copy this file to `webgui/.env.local` only when auto-detection is not enough.
# The Web GUI shells out to the Python CLI from the detected repository root and
# works without this file in the normal root pnpm workspace flow.
AGENTIC_TRADER_CLI=agentic-trader
AGENTIC_TRADER_PYTHON=
# Optional operator token for Web GUI API routes. When unset, route handlers
# accept same-origin requests only when the app-owned loopback launcher sets
# AGENTIC_TRADER_WEBGUI_LOOPBACK_ONLY=1. Set a token before any non-local or
# reverse-proxied Web GUI exposure.
AGENTIC_TRADER_WEBGUI_TOKEN=

# Keep these relative to the repository root because Web GUI route handlers run
# the Python CLI with the root as cwd. Python runtime/provider secrets belong in
# the root `.env.local`, not in tracked Web GUI config.
AGENTIC_TRADER_RUNTIME_DIR=runtime
AGENTIC_TRADER_DATABASE_PATH=runtime/agentic_trader.duckdb
